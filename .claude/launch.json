{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Minhas Patas",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "minhas-patas", "--no-clipboard", "-l", "3456"],
      "port": 3456
    },
    {
      "name": "Minhas Patas App",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--port", "5177"],
