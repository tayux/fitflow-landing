    }
  ,{
      "name": "Storybook",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "storybook", "--", "--port", "6006", "--no-open"],
      "port": 6006,
      "cwd": "minhas-patas-app"
    }
  ]
}
